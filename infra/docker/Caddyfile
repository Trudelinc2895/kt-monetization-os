# KT Monetization OS — Caddyfile
# Auto-HTTPS via Let's Encrypt

{env.DOMAIN}, www.{env.DOMAIN} {
    redir https://{env.DOMAIN}{uri} permanent
    reverse_proxy web:3000
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options DENY
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
    }
    encode gzip
}

api.{env.DOMAIN} {
    reverse_proxy api:8010
    header X-Frame-Options DENY
    header X-Content-Type-Options nosniff
}

admin.{env.DOMAIN} {
    reverse_proxy admin:3020
    header X-Frame-Options DENY
}

monitor.{env.DOMAIN} {
    reverse_proxy grafana:3030
    basicauth {
        kevin JDJhJDEwJHhleVpWaFhxZElRZ1lXa1lwa1FuVWVPbEZoVUlnSkJCQW9ISlN4emJ5VW0uc3pYVFhUU2dD
    }
}

